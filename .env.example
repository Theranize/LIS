# LIS Server Environment Configuration
# 
# Copy this file to .env and update values for your environment
# Uncomment and modify as needed

# TCP Server Configuration
TCP_PORT=5001
TCP_HOST=0.0.0.0

# Express API Configuration
API_PORT=3000
API_HOST=0.0.0.0

# MySQL Database Configuration - Analyzer Engine Database (Main Node.js DB)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=analyzer_engine_db
DB_CONNECTION_LIMIT=10

# Diagnostic Master Database Configuration (Centralized Configuration DB)
MASTER_DB_HOST=localhost
MASTER_DB_USER=root
MASTER_DB_PASSWORD=
MASTER_DB_NAME=diagnostic_master_db

# Default Analyzer ID
DEFAULT_ANALYZER_ID=1

# Node.js API URL for CodeIgniter integration
NODE_ANALYZER_API_URL=http://localhost:3000/api

# Analyzer Configuration
ANALYZER_ID=ANALYZER_001
ANALYZER_MODEL=Mindray BS-230

# Logging Configuration
LOG_LEVEL=info
# Options: debug, info, warn, error

# Application Mode
NODE_ENV=development
# Options: development, production
